{
  "name": "htsl-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo HTSL : moteur (packages/core), extensions CodeMirror (htsl-codemirror) et playground.",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/codemirror",
    "playground"
  ],
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev": "npm run dev --workspace playground"
  },
  "license": "MIT"
}
