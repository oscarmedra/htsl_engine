{
  "name": "@noah-medra/htsl-core",
  "version": "0.1.1",
  "description": "HTSL (HyperText Structured Language) — declarative markup engine for math/physics documents: parser, renderer and runtime that compiles to HTML through an AST.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist-min/*": "./dist-min/*"
  },
  "files": [
    "dist",
    "dist-min",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oscarmedra/htsl_engine.git",
    "directory": "packages/core"
  },
  "homepage": "https://oscarmedra.github.io/htsl_engine/",
  "bugs": "https://github.com/oscarmedra/htsl_engine/issues",
  "author": "oscarmedra",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:min": "tsup --config tsup.min.config.ts",
    "build:all": "npm run build && npm run build:min",
    "prepublishOnly": "npm run build:all",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo": "tsx scripts/demo.ts",
    "demo:formulas": "tsx scripts/demo-formulas.ts",
    "demo:geometry": "tsx scripts/demo-geometry.ts"
  },
  "keywords": [
    "htsl",
    "markup",
    "html",
    "parser",
    "ast",
    "lexer",
    "renderer"
  ],
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
