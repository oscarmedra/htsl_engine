{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "paths": {
      "@noah-medra/htsl-core": ["../packages/core/src/index.ts"],
      "@noah-medra/htsl-codemirror": ["../packages/codemirror/src/index.ts"]
    }
  },
  "include": ["src"]
}
